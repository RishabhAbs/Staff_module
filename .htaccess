Options -MultiViews -Indexes
RewriteEngine On
RewriteBase /

# ── Block direct access to sensitive backend files ───────────────────────────
RewriteRule ^backend/\.env$        - [F,L]
RewriteRule ^backend/src(/.*)?$    - [F,L]

# ── Proxy ALL requests to Node.js on port 5280 ───────────────────────────────
# Node.js serves both the REST API (/api/*) and the React SPA (index.html)
RewriteRule ^(.*)$ http://127.0.0.1:5281/$1 [P,L,QSA]
